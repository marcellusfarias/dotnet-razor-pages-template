@page
@model MyBuyingList.Web.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Users";
}

<h1>Users</h1>

<p><a href="/users/create">Create New User</a></p>

<table>
    <thead>
        <tr>
            <th>ID</th>
            <th>Username</th>
            <th>Email</th>
            <th>Active</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model.Users.Data)
        {
            <tr>
                <td>@user.Id</td>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>@user.Active</td>
                <td>
                    <a href="/users/@user.Id/change-password">Change Password</a>
                    &nbsp;|&nbsp;
                    <a href="/users/@user.Id/delete">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.Users.TotalPages > 1)
{
    <nav>
        @for (int i = 1; i <= Model.Users.TotalPages; i++)
        {
            <a href="/users?page=@i">@i</a>
        }
    </nav>
}
