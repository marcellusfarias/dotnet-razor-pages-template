@page "/users/{id:int}/change-password"
@model MyBuyingList.Web.Pages.Users.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<h1>Change Password</h1>

<form method="post">
    <div>
        <label asp-for="Input.OldPassword">Current Password</label>
        <input asp-for="Input.OldPassword" type="password" />
        <span asp-validation-for="Input.OldPassword"></span>
    </div>

    <div>
        <label asp-for="Input.NewPassword">New Password</label>
        <input asp-for="Input.NewPassword" type="password" />
        <span asp-validation-for="Input.NewPassword"></span>
    </div>

    <div asp-validation-summary="ModelOnly"></div>

    <button type="submit">Change Password</button>
    <a href="/users">Cancel</a>
</form>
