{
  "SecretsLocation": "/run/secrets",
  "CookieAuthOptions": {
    "ExpirationMinutes": 60,
    "SlidingExpiration": true
  },
  "CustomRateLimiterOptions": {
    "PermitLimit": 1,
    "QueueLimit": 0,
    "Window": 5
  },
  "LockoutOptions": {
    "MaxFailedAttempts": 5,
    "LockoutDurationMinutes": 15
  },
  "RepositorySettings": {
    "PageSize": 10
  },
  "DataProtection": {
    "KeysPath": "/root/.aspnet/DataProtection-Keys"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Seq": {
    "ServerUrl": "http://seq:5341"
  }
}
